@page "/employees"
@using PosSystem.Shared.Models
@using PosSystem.Client.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<LocalDbContext> DbFactory

<PageTitle>Empleados - Frutería Martín</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">👥 Gestión de Empleados</h1>
    <button class="btn btn-success" @onclick="OpenAddModal">
        ➕ Nuevo Empleado
    </button>
</div>

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible py-2 mb-3">
        ✅ @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}
@if (errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible py-2 mb-3">
        ❌ @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<!-- EMPLOYEE TABLE -->
@if (employees == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Cargando empleados...</p>
    </div>
}
else if (!employees.Any())
{
    <div class="alert alert-info text-center">No hay empleados registrados aún.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Rol</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Registrado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in employees)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@emp.Id</span></td>
                                <td class="fw-bold">@emp.Name</td>
                                <td>
                                    @if (emp.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">🛡️ Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">🧾 Cajero</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (emp.IsActive)
                                    {
                                        <span class="badge bg-success">● Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">○ Inactivo</span>
                                    }
                                </td>
                                <td class="text-center text-muted" style="font-size: 0.85rem;">
                                    @emp.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary me-1"
                                            @onclick="() => OpenEditModal(emp)"
                                            title="Editar">
                                        ✏️ Editar
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ConfirmDelete(emp)"
                                            title="Eliminar"
                                            disabled="@(emp.Role == "Admin" && employees.Count(e => e.Role == "Admin") == 1)">
                                        🗑️ Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <p class="text-muted mt-2" style="font-size: 0.8rem;">
        ⚠️ No puedes eliminar el último Admin del sistema.
    </p>
}

<!-- ==========================================
     MODAL: AGREGAR / EDITAR EMPLEADO
     ========================================== -->
@if (showFormModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header @(isEditing ? "bg-primary" : "bg-success") text-white">
                    <h5 class="modal-title">
                        @(isEditing ? "✏️ Editar Empleado" : "➕ Nuevo Empleado")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">👤 Nombre completo</label>
                        <input type="text" class="form-control" @bind="formName" placeholder="Ej. Juan López" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">🏷️ Rol</label>
                        <select class="form-select" @bind="formRole">
                            <option value="Cashier">🧾 Cajero</option>
                            <option value="Admin">🛡️ Administrador</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            🔒 @(isEditing ? "Nueva contraseña (dejar vacío para no cambiar)" : "Contraseña")
                        </label>
                        <input type="password" class="form-control" @bind="formPassword"
                               placeholder="@(isEditing ? "••••••••  (opcional)" : "Mínimo 6 caracteres")" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="isActiveCheck"
                                   @bind="formIsActive" />
                            <label class="form-check-label fw-semibold" for="isActiveCheck">
                                Empleado activo
                            </label>
                        </div>
                    </div>

                    @if (formError != null)
                    {
                        <div class="alert alert-danger py-2">@formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button class="btn @(isEditing ? "btn-primary" : "btn-success")"
                            @onclick="SaveEmployee" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(isEditing ? "Guardar Cambios" : "Crear Empleado")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ==========================================
     MODAL: CONFIRMAR ELIMINAR
     ========================================== -->
@if (showDeleteModal && employeeToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">🗑️ Confirmar Eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <div style="font-size: 3rem;">⚠️</div>
                    <h5>¿Eliminar a <strong>@employeeToDelete.Name</strong>?</h5>
                    <p class="text-muted">Esta acción no se puede deshacer. El empleado será eliminado permanentemente del sistema.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="DeleteEmployee" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Sí, eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // --- Data ---
    private List<Employee>? employees;

    // --- UI State ---
    private bool showFormModal = false;
    private bool showDeleteModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;

    // --- Form Fields ---
    private int editingId = 0;
    private string formName = "";
    private string formRole = "Cashier";
    private string formPassword = "";
    private bool formIsActive = true;
    private string? formError;

    // --- Delete ---
    private Employee? employeeToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        employees = await db.Employees.OrderBy(e => e.Id).ToListAsync();
    }

    // --- ADD ---
    private void OpenAddModal()
    {
        isEditing = false;
        editingId = 0;
        formName = "";
        formRole = "Cashier";
        formPassword = "";
        formIsActive = true;
        formError = null;
        showFormModal = true;
    }

    // --- EDIT ---
    private void OpenEditModal(Employee emp)
    {
        isEditing = true;
        editingId = emp.Id;
        formName = emp.Name;
        formRole = emp.Role;
        formPassword = ""; // Don't pre-fill password
        formIsActive = emp.IsActive;
        formError = null;
        showFormModal = true;
    }

    // --- SAVE (Create or Update) ---
    private async Task SaveEmployee()
    {
        formError = null;

        // Validations
        if (string.IsNullOrWhiteSpace(formName))
        {
            formError = "El nombre es obligatorio.";
            return;
        }
        if (!isEditing && string.IsNullOrWhiteSpace(formPassword))
        {
            formError = "La contraseña es obligatoria para nuevos empleados.";
            return;
        }
        if (!string.IsNullOrWhiteSpace(formPassword) && formPassword.Length < 6)
        {
            formError = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        isSaving = true;
        using var db = await DbFactory.CreateDbContextAsync();

        if (isEditing)
        {
            var emp = await db.Employees.FindAsync(editingId);
            if (emp != null)
            {
                emp.Name = formName.Trim();
                emp.Role = formRole;
                emp.IsActive = formIsActive;
                // Only update password if provided
                if (!string.IsNullOrWhiteSpace(formPassword))
                    emp.PasswordHash = BCrypt.Net.BCrypt.HashPassword(formPassword);

                await db.SaveChangesAsync();
                successMessage = $"Empleado '{emp.Name}' actualizado correctamente.";
            }
        }
        else
        {
            var newEmp = new Employee
            {
                Name = formName.Trim(),
                Role = formRole,
                IsActive = formIsActive,
                CreatedAt = DateTime.UtcNow,
                PasswordHash = BCrypt.Net.BCrypt.HashPassword(formPassword)
            };
            db.Employees.Add(newEmp);
            await db.SaveChangesAsync();
            successMessage = $"Empleado '{newEmp.Name}' creado correctamente.";
        }

        isSaving = false;
        showFormModal = false;
        await LoadData();
    }

    // --- DELETE ---
    private void ConfirmDelete(Employee emp)
    {
        employeeToDelete = emp;
        showDeleteModal = true;
    }

    private async Task DeleteEmployee()
    {
        if (employeeToDelete == null) return;

        isSaving = true;
        using var db = await DbFactory.CreateDbContextAsync();
        var emp = await db.Employees.FindAsync(employeeToDelete.Id);
        if (emp != null)
        {
            db.Employees.Remove(emp);
            await db.SaveChangesAsync();
            successMessage = $"Empleado '{emp.Name}' eliminado.";
        }

        isSaving = false;
        showDeleteModal = false;
        employeeToDelete = null;
        await LoadData();
    }

    private void CloseModal()
    {
        showFormModal = false;
        formError = null;
    }
}
